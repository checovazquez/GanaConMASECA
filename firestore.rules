// ============================================================
// firestore.rules — Reglas de seguridad para Gana con MASECA
//
// INSTRUCCIONES:
// 1. Ve a Firebase Console → Firestore Database → Reglas
// 2. Copia y pega todo el contenido de este archivo
// 3. Haz clic en "Publicar"
//
// Admin configurado: sergiovazquezdezamacona@gmail.com
// ============================================================

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        request.auth.token.email == 'sergiovazquezdezamacona@gmail.com';
    }

    function isOwner(storeId) {
      return isSignedIn() && request.auth.uid == storeId;
    }

    // ── Colección: spins ──────────────────────────────────────
    // Cada tienda solo puede leer y crear sus propios giros.
    // El admin puede leer todos.
    match /spins/{spinId} {
      allow read: if isSignedIn() &&
        (request.auth.uid == resource.data.storeId || isAdmin());

      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.storeId &&
        request.resource.data.keys().hasAll(['storeId','storeEmail','result','isWinner','date','hour']);

      allow update, delete: if isAdmin();
    }

    // ── Colección: storeStats ─────────────────────────────────
    // Las tiendas actualizan sus propias estadísticas.
    // El admin puede leer todas (para el dashboard).
    match /storeStats/{storeId} {
      allow read: if isSignedIn() &&
        (isOwner(storeId) || isAdmin());

      allow write: if isSignedIn() &&
        (isOwner(storeId) || isAdmin());
    }

    // ── Colección: config ─────────────────────────────────────
    // Todas las tiendas autenticadas pueden leer la config global.
    // Solo el admin puede escribirla.
    match /config/{docId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
